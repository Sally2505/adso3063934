{
  "name": "syte-dc-expo",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "set REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.28&& expo start --host lan",
    "start:clear": "set REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.28&& expo start --host lan --clear",
    "start:go": "set REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.28&& expo start --host lan --port 8090 --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.3.0",
    "expo": "~54.0.0",
    "expo-font": "~14.0.0",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-preset-expo": "~54.0.0"
  }
}
